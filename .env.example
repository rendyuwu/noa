# --- Shared local development env (repo root) ---
# Copy to: ./.env
#
# NOTE: This file is for LOCAL development convenience.
# In production (K8s), provide env via ConfigMaps/Secrets instead.

# Runtime
ENVIRONMENT=development

# Database
POSTGRES_URL=postgresql+asyncpg://noa:noa@localhost:5432/noa
NOA_DB_SECRET_KEY=replace-with-a-generated-fernet-key
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# Auth / JWT
AUTH_JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_LOGIN_RATE_LIMIT_BLOCK_SECONDS=600
AUTH_BOOTSTRAP_ADMIN_EMAILS=["admin@example.com","smoke@example.com"]
# AUTH_DEV_BYPASS_LDAP=true

# CORS
API_CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
API_CORS_ALLOW_CREDENTIALS=true

# LDAP
LDAP_SERVER_URI=ldap://ldap.example.com:389
LDAP_ALLOW_INSECURE_TRANSPORT=true
LDAP_BIND_DN=svc-noa@example.com
LDAP_BIND_PASSWORD=replace-with-ldap-password
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_FILTER=(|(mail={email})(userPrincipalName={email}))
LDAP_TIMEOUT_SECONDS=5

# LLM (API + Web display label)
LLM_MODEL=gpt-4o-mini
# Required for the assistant runtime; there is no demo fallback path.
LLM_API_KEY=replace-with-llm-api-key
# LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
# LLM_SYSTEM_PROMPT=You are NOA. Use tools when they help answer the user request.
# LLM_SYSTEM_PROMPT_PATH=/absolute/or/relative/path/to/system-prompt.md
# LLM_SYSTEM_PROMPT_EXTRA_PATHS=/path/to/org-rules.md,/path/to/team-rules.md

# Telemetry (OpenTelemetry)
# TELEMETRY_ENABLED=true
# TELEMETRY_SERVICE_NAME=noa-api
# TELEMETRY_OTLP_ENDPOINT=http://localhost:4318
# TELEMETRY_OTLP_HEADERS=authorization=Bearer token, x-tenant-id=tenant-123
# TELEMETRY_TRACES_ENABLED=true
# TELEMETRY_METRICS_ENABLED=true

# Web -> API proxy target (server-side only)
NOA_API_URL=http://localhost:8000

# Web observability
NEXT_PUBLIC_ERROR_REPORTING_ENABLED=false
NEXT_PUBLIC_ERROR_REPORTING_DSN=
NEXT_PUBLIC_ERROR_REPORTING_ENVIRONMENT=development
